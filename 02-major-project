          "text": [
            "Welcome to AthletiLog – Football Activity & Performance Manager\n",
            "\n",
            "====== AthletiLog Menu ======\n",
            "1. Add team\n",
            "2. View teams\n",
            "3. Add football activity\n",
            "4. View all activities\n",
            "5. Edit activity\n",
            "6. Delete activity\n",
            "7. Filter activities by type\n",
            "8. Show summary report\n",
            "9. Exit\n"
          ]
        }
      ],
      "source": [
        "\"\"\"\n",
        "AthletiLog – Football Activity & Performance Manager\n",
        "ISYS5002 Introduction to Programming Project\n",
        "Pathway A: Personal Life Improvement\n",
        "\n",
        "This command-line program helps track football activities such as matches,\n",
        "training sessions, attendance, expenses, and performance notes.\n",
        "\n",
        "Note: This program uses only Python standard library modules.\n",
        "\"\"\"\n",
        "\n",
        "import json\n",
        "import os\n",
        "\n",
        "DATA_FILE = \"athletilog_data.json\"\n",
        "\n",
        "\n",
        "def load_data():\n",
        "    \"\"\"Load activity data from a local JSON file.\"\"\"\n",
        "    if os.path.exists(DATA_FILE):\n",
        "        with open(DATA_FILE, \"r\") as file:\n",
        "            return json.load(file)\n",
        "    return {\"activities\": {}, \"teams\": {}}\n",
        "\n",
        "\n",
        "def save_data(data):\n",
        "    \"\"\"Save activity data to a local JSON file.\"\"\"\n",
        "    with open(DATA_FILE, \"w\") as file:\n",
        "        json.dump(data, file, indent=4)\n",
        "\n",
        "\n",
        "def get_non_empty_input(prompt):\n",
        "    \"\"\"Keep asking until the user enters something.\"\"\"\n",
        "    value = input(prompt).strip()\n",
        "    while value == \"\":\n",
        "        print(\"Input cannot be empty. Please try again.\")\n",
        "        value = input(prompt).strip()\n",
        "    return value\n",
        "\n",
        "\n",
        "def get_float_input(prompt):\n",
        "    \"\"\"Keep asking until the user enters a valid number.\"\"\"\n",
        "    value = input(prompt).strip()\n",
        "    while not value.replace(\".\", \"\", 1).isdigit():\n",
        "        print(\"Please enter a valid number.\")\n",
        "        value = input(prompt).strip()\n",
        "    return float(value)\n",
        "\n",
        "\n",
        "def get_rating_input(prompt):\n",
        "    \"\"\"Ask for a performance rating between 1 and 10.\"\"\"\n",
        "    value = input(prompt).strip()\n",
        "    while not value.isdigit() or int(value) < 1 or int(value) > 10:\n",
        "        print(\"Please enter a whole number between 1 and 10.\")\n",
        "        value = input(prompt).strip()\n",
        "    return int(value)\n",
        "\n",
        "\n",
        "def add_team(data):\n",
        "    \"\"\"Add a team and its players.\"\"\"\n",
        "    team_name = get_non_empty_input(\"Enter team name: \")\n",
        "\n",
        "    players_text = get_non_empty_input(\"Enter player names separated by commas: \")\n",
        "    players = [player.strip() for player in players_text.split(\",\") if player.strip() != \"\"]\n",
        "\n",
        "    data[\"teams\"][team_name] = players\n",
        "    save_data(data)\n",
        "    print(\"Team added successfully!\")\n",
        "\n",
        "\n",
        "def view_teams(data):\n",
        "    \"\"\"Display all teams and players.\"\"\"\n",
        "    if len(data[\"teams\"]) == 0:\n",
        "        print(\"No teams found.\")\n",
        "        return\n",
        "\n",
        "    print(\"\\n--- Teams ---\")\n",
        "    for team_name, players in data[\"teams\"].items():\n",
        "        print(\"\\nTeam:\", team_name)\n",
        "        print(\"Players:\", \", \".join(players))\n",
        "\n",
        "\n",
        "def add_activity(data):\n",
        "    \"\"\"Add a new football activity.\"\"\"\n",
        "    activity_id = str(len(data[\"activities\"]) + 1)\n",
        "\n",
        "    activity_type = get_non_empty_input(\"Enter activity type (match/training/practice): \").lower()\n",
        "    date = get_non_empty_input(\"Enter date (example: 2026-05-08): \")\n",
        "    location = get_non_empty_input(\"Enter location: \")\n",
        "    team = get_non_empty_input(\"Enter team name: \")\n",
        "\n",
        "    attendance = get_non_empty_input(\"Did you attend? (yes/no): \").lower()\n",
        "    while attendance not in [\"yes\", \"no\"]:\n",
        "        print(\"Please type yes or no.\")\n",
        "        attendance = get_non_empty_input(\"Did you attend? (yes/no): \").lower()\n",
        "\n",
        "    expense = get_float_input(\"Enter expense amount in AUD: \")\n",
        "    rating = get_rating_input(\"Enter performance rating (1-10): \")\n",
        "    notes = get_non_empty_input(\"Enter performance notes: \")\n",
        "\n",
        "    data[\"activities\"][activity_id] = {\n",
        "        \"type\": activity_type,\n",
        "        \"date\": date,\n",
        "        \"location\": location,\n",
        "        \"team\": team,\n",
        "        \"attendance\": attendance,\n",
        "        \"expense\": expense,\n",
        "        \"rating\": rating,\n",
        "        \"notes\": notes\n",
        "    }\n",
        "\n",
        "    save_data(data)\n",
        "    print(\"Activity added successfully!\")\n",
        "\n",
        "\n",
        "def view_activities(data):\n",
        "    \"\"\"Display all saved football activities.\"\"\"\n",
        "    if len(data[\"activities\"]) == 0:\n",
        "        print(\"No activities found.\")\n",
        "        return\n",
        "\n",
        "    print(\"\\n--- Football Activities ---\")\n",
        "    for activity_id, details in data[\"activities\"].items():\n",
        "        print(\"\\nActivity ID:\", activity_id)\n",
        "        print(\"Type:\", details[\"type\"])\n",
        "        print(\"Date:\", details[\"date\"])\n",
        "        print(\"Location:\", details[\"location\"])\n",
        "        print(\"Team:\", details[\"team\"])\n",
        "        print(\"Attendance:\", details[\"attendance\"])\n",
        "        print(\"Expense: AUD\", details[\"expense\"])\n",
        "        print(\"Performance Rating:\", details[\"rating\"])\n",
        "        print(\"Notes:\", details[\"notes\"])\n",
        "\n",
        "\n",
        "def edit_activity(data):\n",
        "    \"\"\"Edit selected fields in an existing activity.\"\"\"\n",
        "    if len(data[\"activities\"]) == 0:\n",
        "        print(\"No activities to edit.\")\n",
        "        return\n",
        "\n",
        "    view_activities(data)\n",
        "    activity_id = get_non_empty_input(\"Enter the Activity ID to edit: \")\n",
        "\n",
        "    if activity_id not in data[\"activities\"]:\n",
        "        print(\"Activity ID not found.\")\n",
        "        return\n",
        "\n",
        "    print(\"\\nWhat do you want to update?\")\n",
        "    print(\"1. Type\")\n",
        "    print(\"2. Date\")\n",
        "    print(\"3. Location\")\n",
        "    print(\"4. Team\")\n",
        "    print(\"5. Attendance\")\n",
        "    print(\"6. Expense\")\n",
        "    print(\"7. Rating\")\n",
        "    print(\"8. Notes\")\n",
        "\n",
        "    choice = input(\"Enter your choice: \")\n",
        "\n",
        "    if choice == \"1\":\n",
        "        data[\"activities\"][activity_id][\"type\"] = get_non_empty_input(\"Enter new type: \").lower()\n",
        "    elif choice == \"2\":\n",
        "        data[\"activities\"][activity_id][\"date\"] = get_non_empty_input(\"Enter new date: \")\n",
        "    elif choice == \"3\":\n",
        "        data[\"activities\"][activity_id][\"location\"] = get_non_empty_input(\"Enter new location: \")\n",
        "    elif choice == \"4\":\n",
        "        data[\"activities\"][activity_id][\"team\"] = get_non_empty_input(\"Enter new team: \")\n",
        "    elif choice == \"5\":\n",
        "        attendance = get_non_empty_input(\"Did you attend? (yes/no): \").lower()\n",
        "        while attendance not in [\"yes\", \"no\"]:\n",
        "            print(\"Please type yes or no.\")\n",
        "            attendance = get_non_empty_input(\"Did you attend? (yes/no): \").lower()\n",
        "        data[\"activities\"][activity_id][\"attendance\"] = attendance\n",
        "    elif choice == \"6\":\n",
        "        data[\"activities\"][activity_id][\"expense\"] = get_float_input(\"Enter new expense: \")\n",
        "    elif choice == \"7\":\n",
        "        data[\"activities\"][activity_id][\"rating\"] = get_rating_input(\"Enter new rating (1-10): \")\n",
        "    elif choice == \"8\":\n",
        "        data[\"activities\"][activity_id][\"notes\"] = get_non_empty_input(\"Enter new notes: \")\n",
        "    else:\n",
        "        print(\"Invalid choice.\")\n",
        "        return\n",
        "\n",
        "    save_data(data)\n",
        "    print(\"Activity updated successfully!\")\n",
        "\n",
        "\n",
        "def delete_activity(data):\n",
        "    \"\"\"Delete an activity by ID.\"\"\"\n",
        "    if len(data[\"activities\"]) == 0:\n",
        "        print(\"No activities to delete.\")\n",
        "        return\n",
        "\n",
        "    view_activities(data)\n",
        "    activity_id = get_non_empty_input(\"Enter the Activity ID to delete: \")\n",
        "\n",
        "    if activity_id in data[\"activities\"]:\n",
        "        del data[\"activities\"][activity_id]\n",
        "        save_data(data)\n",
        "        print(\"Activity deleted successfully!\")\n",
        "    else:\n",
        "        print(\"Activity ID not found.\")\n",
        "\n",
        "\n",
        "def filter_by_type(data):\n",
        "    \"\"\"Show activities matching a selected type.\"\"\"\n",
        "    activity_type = get_non_empty_input(\"Enter type to filter (match/training/practice): \").lower()\n",
        "    found = False\n",
        "\n",
        "    print(\"\\n--- Filtered Activities ---\")\n",
        "    for activity_id, details in data[\"activities\"].items():\n",
        "        if details[\"type\"] == activity_type:\n",
        "            found = True\n",
        "            print(\"\\nActivity ID:\", activity_id)\n",
        "            print(\"Date:\", details[\"date\"])\n",
        "            print(\"Location:\", details[\"location\"])\n",
        "            print(\"Team:\", details[\"team\"])\n",
        "            print(\"Attendance:\", details[\"attendance\"])\n",
        "            print(\"Expense: AUD\", details[\"expense\"])\n",
        "            print(\"Rating:\", details[\"rating\"])\n",
        "            print(\"Notes:\", details[\"notes\"])\n",
        "\n",
        "    if not found:\n",
        "        print(\"No activities found for this type.\")\n",
        "\n",
        "\n",
        "def show_summary(data):\n",
        "    \"\"\"Generate a simple summary report.\"\"\"\n",
        "    activities = data[\"activities\"]\n",
        "\n",
        "    if len(activities) == 0:\n",
        "        print(\"No activities available for summary.\")\n",
        "        return\n",
        "\n",
        "    total_expense = 0\n",
        "    attended_count = 0\n",
        "    missed_count = 0\n",
        "    total_rating = 0\n",
        "    type_count = {}\n",
        "\n",
        "    for activity_id, details in activities.items():\n",
        "        total_expense += details[\"expense\"]\n",
        "        total_rating += details[\"rating\"]\n",
        "\n",
        "        if details[\"attendance\"] == \"yes\":\n",
        "            attended_count += 1\n",
        "        else:\n",
        "            missed_count += 1\n",
        "\n",
        "        activity_type = details[\"type\"]\n",
        "        if activity_type in type_count:\n",
        "            type_count[activity_type] += 1\n",
        "        else:\n",
        "            type_count[activity_type] = 1\n",
        "\n",
        "    average_rating = total_rating / len(activities)\n",
        "    most_common_type = max(type_count, key=type_count.get)\n",
        "\n",
        "    print(\"\\n--- AthletiLog Summary Report ---\")\n",
        "    print(\"Total activities:\", len(activities))\n",
        "    print(\"Attended activities:\", attended_count)\n",
        "    print(\"Missed activities:\", missed_count)\n",
        "    print(\"Total expenses: AUD\", round(total_expense, 2))\n",
        "    print(\"Average performance rating:\", round(average_rating, 2))\n",
        "    print(\"Most frequent activity type:\", most_common_type)\n",
        "\n",
        "\n",
        "def show_menu():\n",
        "    \"\"\"Display the main menu.\"\"\"\n",
        "    print(\"\\n====== AthletiLog Menu ======\")\n",
        "    print(\"1. Add team\")\n",
        "    print(\"2. View teams\")\n",
        "    print(\"3. Add football activity\")\n",
        "    print(\"4. View all activities\")\n",
        "    print(\"5. Edit activity\")\n",
        "    print(\"6. Delete activity\")\n",
        "    print(\"7. Filter activities by type\")\n",
        "    print(\"8. Show summary report\")\n",
        "    print(\"9. Exit\")\n",
        "\n",
        "\n",
        "def main():\n",
        "    \"\"\"Main program loop.\"\"\"\n",
        "    data = load_data()\n",
        "\n",
        "    print(\"Welcome to AthletiLog – Football Activity & Performance Manager\")\n",
        "\n",
        "    while True:\n",
        "        show_menu()\n",
        "        choice = input(\"Enter your choice (1-9): \")\n",
        "\n",
        "        if choice == \"1\":\n",
        "            add_team(data)\n",
        "        elif choice == \"2\":\n",
        "            view_teams(data)\n",
        "        elif choice == \"3\":\n",
        "            add_activity(data)\n",
        "        elif choice == \"4\":\n",
        "            view_activities(data)\n",
        "        elif choice == \"5\":\n",
        "            edit_activity(data)\n",
        "        elif choice == \"6\":\n",
        "            delete_activity(data)\n",
        "        elif choice == \"7\":\n",
        "            filter_by_type(data)\n",
        "        elif choice == \"8\":\n",
        "            show_summary(data)\n",
        "        elif choice == \"9\":\n",
        "            print(\"Thank you for using AthletiLog. Goodbye!\")\n",
        "            break\n",
        "        else:\n",
        "            print(\"Invalid choice. Please choose a number from 1 to 9.\")\n",
        "\n",
        "\n",
        "main()"
      ]
    }
  ]
